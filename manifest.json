{
  "manifest_version": 3,
  "name": "Claude Navigation Sidebar",
  "version": "0.2.0",
  "description": "Sidebar that bookmarks your reading position and dispatches selections to a sidecar tab.",
  "permissions": ["tabs", "storage"],
  "content_scripts": [
    {
      "matches": ["https://claude.ai/*", "https://gemini.google.com/*"],
      "js": ["content.js"],
      "css": ["sidebar.css"],
      "run_at": "document_idle"
    }
  ],
  "background": {
    "service_worker": "background.js"
  }
}
